{"id":1,"name":"Dream","note":"","pages":[{"conditions":{"actorId":1,"actorValid":false,"itemId":1,"itemValid":false,"selfSwitchCh":"A","selfSwitchValid":false,"switch1Id":1,"switch1Valid":false,"switch2Id":1,"switch2Valid":false,"variableId":1,"variableValid":false,"variableValue":0},"directionFix":false,"image":{"characterIndex":0,"characterName":"","direction":2,"pattern":0,"tileId":0},"list":[{"code":245,"indent":0,"parameters":[{"name":"Hollow Knight - Cave Atmosphere Misc. 3","volume":50,"pitch":100,"pan":0}]},{"code":230,"indent":0,"parameters":[180]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["..."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["I keep thinking about what Doran said."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["\"I've been running this facility for three years without"]},{"code":401,"indent":0,"parameters":["incident.\""]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["Three years..."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["As if time without consequence is the same as safety."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["As if the forest has been fine this whole time."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["As if the stumps and the bare soil and the empty Grove"]},{"code":401,"indent":0,"parameters":["don't count as incidents."]},{"code":230,"indent":0,"parameters":[120]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["I don't think he's a bad person."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["That's what makes it hard..."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["Bad people are easy to negotiate."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["You push back, you draw a line, you move on."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["But Doran genuinely believes he's doing right by this place,"]},{"code":401,"indent":0,"parameters":["and by these people."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["And in some ways, he is."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["That's the part I can't resolve."]},{"code":230,"indent":0,"parameters":[120]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["But then I think about Tomo."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["Sitting there with that serious look on his face, asking me"]},{"code":401,"indent":0,"parameters":["if the forest is really sick."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["And I told him yes, because he deserved the truth."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["He just... nodded."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["Like he'd already known, and just needed someone to say it"]},{"code":401,"indent":0,"parameters":["out loud."]},{"code":230,"indent":0,"parameters":[120]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["I didn't expect the community to be watching."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["I came here to do a job. Document, restore, report."]},{"code":401,"indent":0,"parameters":["Rinse and repeat."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["That was the plan anyway..."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["But somewhere between the riverbank and the Restoration"]},{"code":401,"indent":0,"parameters":["Zone and the Grove..."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["...something shifted."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["Mara stopped pretending not to notice."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["Soren started talking about things he hadn't spoken about"]},{"code":401,"indent":0,"parameters":["in years."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["Even the people who never looked up when I walked past..."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["I can feel something changing."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["Slowly. The way everything in a forest changes."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["Not all at once."]},{"code":401,"indent":0,"parameters":["Not dramatically."]},{"code":401,"indent":0,"parameters":["Just a little more green where there was none before."]},{"code":230,"indent":0,"parameters":[120]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["The journal pages..."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["Whoever left them behind spent years in that Grove."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["Years of quiet, careful work that nobody else was doing."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["And somewhere in that work, they found something nobody"]},{"code":401,"indent":0,"parameters":["else had seen."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["Or something everyone had forgotten to keep looking for."]},{"code":230,"indent":0,"parameters":[120]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["I hope it's still out there..."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["I hope the forest has been keeping it safe..."]},{"code":230,"indent":0,"parameters":[120]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["Tomorrow I'll go back."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["There's always still work to do."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["But tonight..."]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["Tonight I think we're going to be okay."]},{"code":230,"indent":0,"parameters":[180]},{"code":246,"indent":0,"parameters":[4]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["I think Silvoria is going to be okay. \\| \\| \\| \\| \\| \\^"]},{"code":230,"indent":0,"parameters":[240]},{"code":241,"indent":0,"parameters":[{"name":"[Wildfire] Ambient Silk Escalated - Christopher Larkin","volume":20,"pitch":100,"pan":0}]},{"code":230,"indent":0,"parameters":[360]},{"code":245,"indent":0,"parameters":[{"name":"Forest Fire  Sound Effect (Copyright Free)","volume":20,"pitch":100,"pan":0}]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":[".\\..\\..\\.W\\.h\\.a\\.t\\. i\\.s\\. t\\.h\\.a\\.t\\. s\\.m\\.e\\.l\\.l\\.?\\. \\| \\| \\| \\| \\^"]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["...N\\.o\\..\\..\\..\\. \\| \\| \\| \\| \\^"]},{"code":101,"indent":0,"parameters":["",0,2,1,""]},{"code":401,"indent":0,"parameters":["N\\.o\\.,\\. n\\.o\\.,\\. n\\.o\\.-\\. \\| \\| \\| \\| \\^"]},{"code":250,"indent":0,"parameters":[{"name":"Undertale - Exit sound effect","volume":100,"pitch":100,"pan":0}]},{"code":242,"indent":0,"parameters":[5]},{"code":246,"indent":0,"parameters":[5]},{"code":230,"indent":0,"parameters":[300]},{"code":221,"indent":0,"parameters":[]},{"code":201,"indent":0,"parameters":[0,23,8,6,0,0]},{"code":222,"indent":0,"parameters":[]},{"code":0,"indent":0,"parameters":[]}],"moveFrequency":3,"moveRoute":{"list":[{"code":0,"parameters":[]}],"repeat":true,"skippable":false,"wait":false},"moveSpeed":3,"moveType":0,"priorityType":0,"stepAnime":false,"through":false,"trigger":3,"walkAnime":true}],"x":0,"y":0}
